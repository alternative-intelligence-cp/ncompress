// Update CRC32 with `len` bytes at raw address `data`.
// Direct per-bit computation: reflected poly 0xEDB88320 = -306674912i32.
// The odd-branch arithmetic right shift sign-extends, but the poly XOR corrects it.
// The even-branch masks the sign bit with 0x7FFFFFFF (= 2147483647).
pub func:crc32_update = NIL(wild CRC32-> : ctx, int64:data, int64:len) {
    if (len <= 0i64) { pass; }
    int32:crc = ctx->crc;
    int64:i   = 0i64;
    while (i < len) {
        int32:byte = cast_unchecked<int32>(raw load8(data + i)) & 255i32;
        crc = crc ^ byte;
        int32:b = 0i32;
        while (b < 8i32) {
            if ((crc & 1i32) == 1i32) {
                // Logical right shift (clear sign bit) then XOR with poly
                crc = ((crc >> 1i32) & 2147483647i32) ^ -306674912i32;
            } else {
                // Logical right shift only
                crc = (crc >> 1i32) & 2147483647i32;
            }
            b = b + 1i32;
        }
        i = i + 1i64;
    }
    ctx->crc = crc;
    pass;
};

// Produce final CRC32 value (XOR with 0xFFFFFFFF = -1 as signed int32).
pub func:crc32_finish = int32(wild CRC32-> : ctx) {
    pass ctx->crc ^ -1i32;
};
