// checksum.npk
// Adler32 (RFC 1950 §8.2) and CRC32 (IEEE 802.3) implementations.
//
// Adler32: modular checksum used in zlib (PNG IDAT).
//   - Two running sums A and B, modulo 65521 (largest prime < 2^16).
//   - NMAX=5552: max bytes per block before deferred modulo (avoids overflow).
//
// CRC32: IEEE 802.3 reflected polynomial 0xEDB88320.
//   - Used in PNG chunks and gzip.
//   - Table-driven: all 256 entries precomputed as signed int32 constants.
//
// Security invariants:
//   - All data pointer accesses are bounded by the caller-supplied `len`.

use "errors.npk".*;
use "mem.npk".*;


// ─────────────────────────────────────────────────────────────
// Adler32
// ─────────────────────────────────────────────────────────────

pub struct:Adler32 = {
    int32:a;  // running sum A (mod 65521), initialised to 1
    int32:b;  // running sum B (mod 65521), initialised to 0
};

pub func:adler32_init = NIL(wild Adler32-> : ctx) {
    ctx->a = 1i32;
    ctx->b = 0i32;
    pass;
};

// Update Adler32 with `len` bytes at raw address `data`.
pub func:adler32_update = NIL(wild Adler32-> : ctx, int64:data, int64:len) {
    if (len <= 0i64) { pass; }

    int32:a    = ctx->a;
    int32:b    = ctx->b;
    int64:i    = 0i64;
    int64:rem  = len;

    while (rem > 0i64) {
        // Max block before modulo (NMAX = 5552, standard Adler32 optimisation)
        int32:block = cast_unchecked<int32>(rem);
        if (block > 5552i32) { block = 5552i32; }

        int32:j = 0i32;
        while (j < block) {
            int32:byte = cast_unchecked<int32>(raw load8(data + i)) & 255i32;
            a = a + byte;
            b = b + a;
            j = j + 1i32;
            i = i + 1i64;
        }

        a = a % 65521i32;
        b = b % 65521i32;
        rem = rem - cast_unchecked<int64>(block);
    }

    ctx->a = a;
    ctx->b = b;
    pass;
};

// Produce final Adler32 value: (B << 16) | A
pub func:adler32_finish = int32(wild Adler32-> : ctx) {
    pass (ctx->b << 16i32) | ctx->a;
};

// ─────────────────────────────────────────────────────────────
// CRC32 — IEEE 802.3 reflected poly 0xEDB88320
// All 256 table entries precomputed as signed int32 literals.
// ─────────────────────────────────────────────────────────────

pub struct:CRC32 = {
    int32:crc;  // running CRC, initialised to -1 (0xFFFFFFFF)
};

pub func:crc32_init = NIL(wild CRC32-> : ctx) {
    ctx->crc = -1i32; // 0xFFFFFFFF as signed int32
    pass;
};

// CRC32 table lookup — all 256 entries (poly 0xEDB88320, reflected).
func:_crc32_table_entry = int32(int32:idx) {
    idx = idx & 255i32;
    if (idx ==   0i32) { pass 0i32; }
    if (idx ==   1i32) { pass 1996959894i32; }
