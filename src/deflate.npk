pub struct:DeflateState = {
    int64:output_buffer;
    int64:output_pos;
    int64:output_cap;
};

pub func:deflatestate_init = NIL(wild DeflateState-> : state, int64:out_ptr, int64:out_cap) {
    state->output_buffer = out_ptr;
    state->output_pos = 0i64;
    state->output_cap = out_cap;
    pass;
};

