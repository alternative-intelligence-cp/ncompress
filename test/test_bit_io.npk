use "../src/bit_io.npk".*;

pub func:failsafe = int32(tbb32:err) { drop err;
    exit 1i32;
};

pub func:main = int32() {
    BitReader:reader = BitReader{data: 0i64, len: 0i64, byte_pos: 0i64, bit_pos: 0i32};
    drop reader;
    
    BitWriter:writer = BitWriter{data: 0i64, capacity: 0i64, byte_pos: 0i64, bit_pos: 0i32};
    drop writer;
    
    exit 0i32;
};
