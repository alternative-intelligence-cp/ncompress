// test/test_deflate.npk
// Tests for DEFLATE decompression (RFC 1951) and zlib wrapper (RFC 1950).
//
// Test 1: Raw DEFLATE uncompressed block (BTYPE=00)
//   Input: BFINAL=1, BTYPE=00, LEN=5, NLEN=65530, "Hello"
//   Expected output: [72, 101, 108, 108, 111] ("Hello")
//
// Test 2: zlib-wrapped DEFLATE fixed Huffman (BTYPE=01)
//   Generated by Python: zlib.compress(b"Hello", level=1)
//   Compressed: [120, 1, 243, 72, 205, 201, 201, 7, 0, 5, 140, 1, 245]
//   Expected output: [72, 101, 108, 108, 111]
//
// Test 3: zlib-wrapped uncompressed block
//   Generated by Python: zlib.compress(b"Hello", level=0)
//   Compressed: [120, 1, 1, 5, 0, 250, 255, 72, 101, 108, 108, 111, 5, 140, 1, 245]
//   Expected output: [72, 101, 108, 108, 111]

use "../src/deflate.npk".*;
use "../src/zlib.npk".*;
use "../src/bit_io.npk".*;
use "../src/checksum.npk".*;
use "../src/errors.npk".*;
use "../src/mem.npk".*;

extern "nitpick_libc_mem" {
    func:nitpick_libc_mem_calloc = int64(int64:count, int64:size);
    func:nitpick_libc_mem_free   = void(int64:ptr);
}

pub func:failsafe = int32(tbb32:err) { drop(err); exit(1i32); };

pub func:main = int32() {
    int32:status = 0i32;

    // =========================================================
    // TEST 1: Raw DEFLATE uncompressed block
    // Input bytes: [1, 5, 0, 250, 255, 72, 101, 108, 108, 111]
    // =========================================================
    wild int8->:in1 = nodrop alloc(16i64);
    int64:a1 = cast_unchecked<int64>(in1);
    drop raw store8(a1 + 0i64, 1i8);     // BFINAL=1, BTYPE=00
    drop raw store8(a1 + 1i64, 5i8);     // LEN low byte
    drop raw store8(a1 + 2i64, 0i8);     // LEN high byte
    drop raw store8(a1 + 3i64, cast_unchecked<int8>(250i32)); // NLEN low byte
    drop raw store8(a1 + 4i64, cast_unchecked<int8>(255i32)); // NLEN high byte
    drop raw store8(a1 + 5i64, 72i8);    // H
    drop raw store8(a1 + 6i64, 101i8);   // e
    drop raw store8(a1 + 7i64, 108i8);   // l
    drop raw store8(a1 + 8i64, 108i8);   // l
    drop raw store8(a1 + 9i64, 111i8);   // o

    wild int8->:out1 = nodrop alloc(64i64);
    int64:o1 = cast_unchecked<int64>(out1);

    BitReader:reader1 = BitReader{data: 0i64, len: 0i64, byte_pos: 0i64, bit_pos: 0i32};
    drop bitreader_init(@reader1, a1, 10i64);

    DeflateState:state1 = DeflateState{output_buffer: 0i64, output_pos: 0i64, output_cap: 0i64};
    drop deflatestate_init(@state1, o1, 64i64);

    int32:r1 = raw deflate_decompress(@reader1, @state1);
    if (r1 != ERR_OK)              { status = 10i32; }
    if (state1.output_pos != 5i64) { status = 11i32; }
    if (status == 0i32) {
        if ((cast_unchecked<int32>(raw load8(o1 + 0i64)) & 255i32) != 72i32)  { status = 12i32; }
        if ((cast_unchecked<int32>(raw load8(o1 + 1i64)) & 255i32) != 101i32) { status = 13i32; }
        if ((cast_unchecked<int32>(raw load8(o1 + 2i64)) & 255i32) != 108i32) { status = 14i32; }
        if ((cast_unchecked<int32>(raw load8(o1 + 3i64)) & 255i32) != 108i32) { status = 15i32; }
        if ((cast_unchecked<int32>(raw load8(o1 + 4i64)) & 255i32) != 111i32) { status = 16i32; }
    }

    dalloc(in1);
    dalloc(out1);

    // =========================================================
    // TEST 2: zlib-wrapped DEFLATE fixed Huffman
    // Compressed: [120, 1, 243, 72, 205, 201, 201, 7, 0, 5, 140, 1, 245]
    // =========================================================
    if (status == 0i32) {
        wild int8->:in2 = nodrop alloc(16i64);
        int64:a2 = cast_unchecked<int64>(in2);
        drop raw store8(a2 + 0i64, 120i8);  // CMF (CM=8, CINFO=7)
        drop raw store8(a2 + 1i64, 1i8);    // FLG
        drop raw store8(a2 + 2i64, cast_unchecked<int8>(243i32)); // DEFLATE data...
        drop raw store8(a2 + 3i64, 72i8);
        drop raw store8(a2 + 4i64, cast_unchecked<int8>(205i32));
        drop raw store8(a2 + 5i64, cast_unchecked<int8>(201i32));
        drop raw store8(a2 + 6i64, cast_unchecked<int8>(201i32));
        drop raw store8(a2 + 7i64, 7i8);
        drop raw store8(a2 + 8i64, 0i8);
        drop raw store8(a2 + 9i64, 5i8);    // Adler32 byte 0 (big-endian)
        drop raw store8(a2 + 10i64, cast_unchecked<int8>(140i32));
        drop raw store8(a2 + 11i64, 1i8);
        drop raw store8(a2 + 12i64, cast_unchecked<int8>(245i32));

        wild int8->:out2 = nodrop alloc(64i64);
        int64:o2 = cast_unchecked<int64>(out2);

        BitReader:reader2 = BitReader{data: 0i64, len: 0i64, byte_pos: 0i64, bit_pos: 0i32};
        drop bitreader_init(@reader2, a2, 13i64);

        DeflateState:state2 = DeflateState{output_buffer: 0i64, output_pos: 0i64, output_cap: 0i64};
        drop deflatestate_init(@state2, o2, 64i64);

        Adler32:adler2 = Adler32{a: 1i32, b: 0i32};

        int32:r2 = raw zlib_decompress(@reader2, @state2, @adler2);
        if (r2 != ERR_OK)               { status = 20i32; }
        if (state2.output_pos != 5i64)   { status = 21i32; }
        if (status == 0i32) {
            if ((cast_unchecked<int32>(raw load8(o2 + 0i64)) & 255i32) != 72i32)  { status = 22i32; }
            if ((cast_unchecked<int32>(raw load8(o2 + 1i64)) & 255i32) != 101i32) { status = 23i32; }
            if ((cast_unchecked<int32>(raw load8(o2 + 2i64)) & 255i32) != 108i32) { status = 24i32; }
            if ((cast_unchecked<int32>(raw load8(o2 + 3i64)) & 255i32) != 108i32) { status = 25i32; }
            if ((cast_unchecked<int32>(raw load8(o2 + 4i64)) & 255i32) != 111i32) { status = 26i32; }
        }

        dalloc(in2);
        dalloc(out2);
    }

    // =========================================================
    // TEST 3: zlib-wrapped uncompressed block
    // Compressed: [120, 1, 1, 5, 0, 250, 255, 72, 101, 108, 108, 111, 5, 140, 1, 245]
    // =========================================================
    if (status == 0i32) {
        wild int8->:in3 = nodrop alloc(20i64);
        int64:a3 = cast_unchecked<int64>(in3);
        drop raw store8(a3 + 0i64, 120i8);  // CMF
        drop raw store8(a3 + 1i64, 1i8);    // FLG
        drop raw store8(a3 + 2i64, 1i8);    // BFINAL=1, BTYPE=00
        drop raw store8(a3 + 3i64, 5i8);    // LEN low
        drop raw store8(a3 + 4i64, 0i8);    // LEN high
        drop raw store8(a3 + 5i64, cast_unchecked<int8>(250i32)); // NLEN low
        drop raw store8(a3 + 6i64, cast_unchecked<int8>(255i32)); // NLEN high
        drop raw store8(a3 + 7i64, 72i8);   // H
        drop raw store8(a3 + 8i64, 101i8);  // e
        drop raw store8(a3 + 9i64, 108i8);  // l
        drop raw store8(a3 + 10i64, 108i8); // l
        drop raw store8(a3 + 11i64, 111i8); // o
        drop raw store8(a3 + 12i64, 5i8);   // Adler32 byte 0
        drop raw store8(a3 + 13i64, cast_unchecked<int8>(140i32)); // byte 1
        drop raw store8(a3 + 14i64, 1i8);   // byte 2
        drop raw store8(a3 + 15i64, cast_unchecked<int8>(245i32)); // byte 3

        wild int8->:out3 = nodrop alloc(64i64);
        int64:o3 = cast_unchecked<int64>(out3);

        BitReader:reader3 = BitReader{data: 0i64, len: 0i64, byte_pos: 0i64, bit_pos: 0i32};
        drop bitreader_init(@reader3, a3, 16i64);

        DeflateState:state3 = DeflateState{output_buffer: 0i64, output_pos: 0i64, output_cap: 0i64};
        drop deflatestate_init(@state3, o3, 64i64);

        Adler32:adler3 = Adler32{a: 1i32, b: 0i32};

        int32:r3 = raw zlib_decompress(@reader3, @state3, @adler3);
        if (r3 != ERR_OK)               { status = 30i32; }
        if (state3.output_pos != 5i64)   { status = 31i32; }
        if (status == 0i32) {
            if ((cast_unchecked<int32>(raw load8(o3 + 0i64)) & 255i32) != 72i32)  { status = 32i32; }
            if ((cast_unchecked<int32>(raw load8(o3 + 4i64)) & 255i32) != 111i32) { status = 33i32; }
        }

        dalloc(in3);
        dalloc(out3);
    }

    exit status;
};
