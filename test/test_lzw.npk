// test/test_lzw.npk
// Tests for GIF LZW decompression.
//
// Test 1: Decode [0,1,2,0,1,2] with min_code_size=2
//   Codes: clear(4,3b), 0(3b), 1(3b), 2(3b), 6(4b=new), 2(4b), eoi(5,4b)
//   Packed bytes: [68, 100, 82]
use "../src/lzw.npk".*;
use "../src/bit_io.npk".*;
use "../src/errors.npk".*;
use "../src/mem.npk".*;

pub func:failsafe = int32(tbb32:err) { drop(err); exit(1i32); };

pub func:main = int32() {
    int32:status = 0i32;

    // Allocate shared LZW working arrays
    wild int8->:prefix_buf = nodrop alloc(16384i64); // 4096 * 4 bytes for int32[]
    wild int8->:suffix_buf = nodrop alloc(4096i64);
    wild int8->:stack_buf  = nodrop alloc(4096i64);
    int64:prefix_addr = @cast_unchecked<int64>(prefix_buf);
    int64:suffix_addr = @cast_unchecked<int64>(suffix_buf);
    int64:stack_addr  = @cast_unchecked<int64>(stack_buf);

    // =========================================================
    // TEST 1: Decode [0,1,2,0,1,2], min_code_size=2
    // Input bytes: [68, 100, 82]
    // Expected output: [0, 1, 2, 0, 1, 2] (6 bytes)
    // =========================================================
    wild int8->:in1 = nodrop alloc(8i64);
    int64:a1 = @cast_unchecked<int64>(in1);
    drop raw store8(a1 + 0i64, 68i8);
    drop raw store8(a1 + 1i64, 100i8);
    drop raw store8(a1 + 2i64, 82i8);

    wild int8->:out1 = nodrop alloc(16i64);
    int64:o1 = @cast_unchecked<int64>(out1);

    BitReader:reader1 = BitReader{data: 0i64, len: 0i64, byte_pos: 0i64, bit_pos: 0i32};
    drop bitreader_init(@reader1, a1, 3i64);

    LzwState:state1 = LzwState{
        output_buffer: 0i64, output_pos: 0i64, output_cap: 0i64,
        min_code_size: 0i32, curr_code_size: 0i32, clear_code: 0i32, eoi_code: 0i32,
        prefix_table: 0i64, suffix_table: 0i64, stack_ptr: 0i64
    };
    drop lzwstate_init(@state1, o1, 16i64, 2i32, prefix_addr, suffix_addr, stack_addr);

    int32:r1 = raw lzw_decompress(@reader1, @state1);
    if (r1 != ERR_OK)           { status = 1i32; }
    if (state1.output_pos != 6i64) { status = 2i32; }

    if ((@cast_unchecked<int32>(raw load8(o1 + 0i64)) & 255i32) != 0i32) { status = 3i32; }
    if ((@cast_unchecked<int32>(raw load8(o1 + 1i64)) & 255i32) != 1i32) { status = 4i32; }
    if ((@cast_unchecked<int32>(raw load8(o1 + 2i64)) & 255i32) != 2i32) { status = 5i32; }
    if ((@cast_unchecked<int32>(raw load8(o1 + 3i64)) & 255i32) != 0i32) { status = 6i32; }
    if ((@cast_unchecked<int32>(raw load8(o1 + 4i64)) & 255i32) != 1i32) { status = 7i32; }
    if ((@cast_unchecked<int32>(raw load8(o1 + 5i64)) & 255i32) != 2i32) { status = 8i32; }

    dalloc(in1);
    dalloc(out1);
    dalloc(prefix_buf);
    dalloc(suffix_buf);
    dalloc(stack_buf);

    exit status;
};
